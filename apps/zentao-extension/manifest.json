{
  "manifest_version": 3,
  "name": "PromptX ZenTao Extension",
  "version": "0.0.1",
  "description": "在禅道 Bug 详情页一键创建 PromptX 任务。",
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
  "default_title": "PromptX ZenTao Extension"
  }
}
